<!DOCTYPE html>
<html>
<head>
    <title>Colspan and Rowspan</title>
</head>
<body>

    <h1>Colspan and Rowspan</h1>

    <table border="1">
        <tr>
            <th>Name</th>
            <th colspan="2">Marks</th>
        </tr>

        <tr>
            <td>Arisha</td>
            <td>Math</td>
            <td>90</td>
        </tr>

        <tr>
            <td rowspan="2">Rahim</td>
            <td>English</td>
            <td>85</td>
        </tr>

        <tr>
            <td>Science</td>
            <td>80</td>
        </tr>
    </table>

</body>
</html>
